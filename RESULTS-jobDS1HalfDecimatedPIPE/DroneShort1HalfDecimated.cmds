ffmpeg_pipe_extract is a function
ffmpeg_pipe_extract () 
{ 
    /usr/bin/time --verbose --output=$LOG --append ffmpeg -hide_banner -y -an -i $1 ${FFMPEG_EXTRACT_FILTER} ${PIPE_DIR}/PIPE.yuv &> ${RESULTS_DIR}/ffmpeg.log
}

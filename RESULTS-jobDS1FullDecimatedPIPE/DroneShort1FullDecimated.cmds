ffmpeg_pipe_extract is a function
ffmpeg_pipe_extract () 
{ 
    /usr/bin/time --verbose --output=$LOG --append ffmpeg -hide_banner -y -an -i $1 ${FFMPEG_EXTRACT_FILTER} ${PIPE_DIR}/PIPE.yuv &> ${RESULTS_DIR}/ffmpeg.log
}
-vf decimate,setpts=N/100/TB

/data/GIT/C-TAP/YUVToBMPStreamFilter 3840 2160 < /data/GIT/C-TAP/PIPE.yuv > /data/GIT/C-TAP/PIPE.bmp 2>>/data/GIT/C-TAP/RESULTS-jobDS1FullDecimatedPIPE/DroneShort1FullDecimated.log.1



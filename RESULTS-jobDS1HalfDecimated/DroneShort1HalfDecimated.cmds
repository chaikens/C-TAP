
ffmpeg_bmp_extract is a function
ffmpeg_bmp_extract () 
{ 
    ffmpeg -xerror -threads 0 -hide_banner -an -i $1 -vf 'scale=trunc(iw/4)*2:trunc(ih/4)*2,decimate,setpts=N/100/TB' thumb%06d.bmp &> $2
}


